# Exemplo de variaveis de ambiente (opcional)
# Copie para .env e ajuste conforme sua operacao local.

WEB_APP_SECRET=sabesp-relatorios-local
WEB_HOST=127.0.0.1
# PORT tem prioridade sobre WEB_PORT em ambientes de container/plataforma.
PORT=5000
WEB_PORT=5000
WEB_DEBUG=0
AUTH_JWT_SECRET=sabesp-relatorios-local
AUTH_JWT_EXP_MINUTES=60

# Banco de dados (Postgres) - padrao recomendado para rodar `python run_web.py` local
DB_ENABLED=1
# Se for subir a aplicacao web dentro do docker-compose (servico web), troque para `db`.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sisg
DB_USER=sisg
DB_PASSWORD=sisg_local
DB_SSLMODE=prefer
# Opcional: sobrescreve montagem de URL acima
# DATABASE_URL=postgresql://sisg:sisg_local@localhost:5432/sisg?sslmode=prefer
DB_CONNECT_TIMEOUT=5
DATABASE_STRICT_STARTUP=0
CONTRACTS_AUTO_INIT_SCHEMA=1

# Caminhos opcionais para sobrescrever defaults da aplicacao
# OUTPUTS_ROOT=saidas
# MASTER_DIR=BASE_MESTRA
# HISTORY_FILE=data/runtime/processing_history.csv
# DRAFT_DIR=data/drafts/web
# NUCLEO_REFERENCE_FILE=config/nucleo_reference.json
# SERVICE_DICTIONARY_CSV=config/service_dictionary.csv
# SERVICE_DICTIONARY_V2_JSON=config/service_dictionary_v2.json
# BASE_GERENCIAL_TEMPLATE=config/base_gerencial_template.xlsx
